generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum RegistrationStatus {
  WAITING
  APPROVED
  WAITLIST
  REJECTED
  COMPLETED
  MISSED
}

enum PaymentType {
  INITIAL
  FINAL
}

enum PaymentStatus {
  LOCKED
  PENDING
  PAID
}

enum RefundStatus {
  PENDING
  COMPLETED
}

enum PaymentMethod {
  ONLINE
  CASH
  UPI
  BANK_TRANSFER
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  clubId String @unique

  fullName String

  email String @unique

  phoneNumber String @unique

  institution String

  department String

  course String?

  year String

  password String

  role String @default("member")

  createdAt DateTime @default(now())

  registrations Registration[]

  membershipStatus String @default("PENDING")

  clubRole String @default("Member")

  // Admin panel sub-permission tier: NONE | FULL | FINANCE | VISUAL | BOOKING
  adminAccessLevel String @default("NONE")

  bloodGroup String?

  dateOfBirth DateTime?

  collegeRollNumber String?

  emergencyContactName String?

  emergencyContactRelation String?

  emergencyContactPhone String?

  upiId String?

  upiPhone String?

  // =========================
  // Government ID Verification
  // =========================

  govtIdType String?

  govtIdNumber String?

  govtIdImageUrl String?

  govtIdStatus String @default("NOT_SUBMITTED")

  govtIdLocked Boolean @default(false)

  govtIdSubmittedAt DateTime?

  govtIdVerifiedAt DateTime?
}

model Trek {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title String

  destination String

  trailType String

  difficulty String

  altitude String

  duration String

  distance String

  // Portfolio Automation
  distanceKm Float @default(0)

  altitudeMeters Int @default(0)

  campNights Int @default(0)

  countsAsPeak Boolean @default(true)

  trekDay String

  date DateTime

  // ===== Historical Archive =====
  // Past treks backfilled from pre-website records — kept out of the
  // current/live trek views and every global cross-trek admin page, only
  // visible in their own season's archive section and their own tabs.

  isHistorical Boolean @default(false)

  season String?

  // ===== Map Location =====
  // Optional coordinates for the homepage trek map — treks without these
  // simply don't render a pin, no backfill required.

  latitude Float?

  longitude Float?

  price Int

  // 1 = pay the whole trek cost in one go (finalPayment stays 0, and the
  // single payment auto-completes both the initial and final payment flags
  // once verified — see the payments/verify and payments/offline routes).
  // 2 = the existing initial-then-final split.
  installments Int @default(2)

  initialPayment Int

  finalPayment Int

  coverImage String?

  seats Int

  description String

  itinerary String?

  requiredItems String[]

  optionalItems String[]

  leaderMessage String?

  transportDetails String?

  weatherNote String?

  reportingInstructions String?

  // =========================
  // Trip Centre
  // =========================

  meetingPoint String?

  meetingTime DateTime?

  whatsappGroupLink String?

  emergencyNumber String?

  tripCentrePublished Boolean @default(false)

  tripCentrePublishedAt DateTime?

  // =========================
  // College Reimbursement
  // =========================

  expectedReimbursementMin Int?

  expectedReimbursementMax Int?

  // =========================

  refundPercentage Int?

  status String @default("Registration Open")

  registrationOpensAt DateTime?

  registrationClosesAt DateTime?

  registrationOpenedManually Boolean @default(false)

  registrationClosedManually Boolean @default(false)

  // Set once the "registrations are open" email has been sent to everyone
  // who clicked Notify Me for this trek — guards against re-sending on
  // every subsequent page view that piggybacks the open-detection check.
  registrationOpenNotifiedAt DateTime?

  createdAt DateTime @default(now())

  registrations Registration[]

  gallery Gallery[]

  expenses Expense[]

  incomes Income[]

  announcements TripAnnouncement[]

  waypoints TrekWaypoint[]
}

// Admin-editable waypoints (trailhead, halfway point, summit, etc.) that
// drive the homepage's in-page 3D terrain preview for upcoming treks — a
// trek only appears in that picker once it has at least one waypoint set.
model TrekWaypoint {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  trekId String @db.ObjectId
  trek   Trek   @relation(fields: [trekId], references: [id])

  label String

  description String?

  latitude Float

  longitude Float

  mediaUrl String?

  mediaType String @default("image")

  order Int @default(0)

  createdAt DateTime @default(now())
}

model Registration {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  registrationNumber String @unique

  // Student
  userId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id])

  // Guest
  isGuest Boolean @default(false)

  guestName        String?
  guestInstitution String?
  guestDepartment  String?
  guestYear        String?
  guestPhoneNumber String?

  // Trek
  trekId String @db.ObjectId
  trek   Trek   @relation(fields: [trekId], references: [id])

  // Registration
  status RegistrationStatus @default(WAITING)

  approvedBy String?
  approvedAt DateTime?

  initialPaymentDeadline DateTime?

  remarks String?

  // ===== Initial Payment =====

  initialPaymentPaid Boolean @default(false)

  initialPaymentPaidAt DateTime?

  initialPaymentId String?

  // ===== Bond Form =====

  bondFormSubmitted Boolean @default(false)

  bondFormSubmittedAt DateTime?

  // ===== Attendance =====

  attendanceMarked Boolean @default(false)

  attendanceMarkedAt DateTime?

  // ===== Final Payment =====

  finalPaymentUnlocked Boolean @default(false)

  finalPaymentPaid Boolean @default(false)

  finalPaymentPaidAt DateTime?

  finalPaymentId String?

  // ===== College Reimbursement =====

  reimbursementAmount Int?

  reimbursementDone Boolean @default(false)

  reimbursementDoneAt DateTime?

  reimbursementReceived Boolean @default(false)

  reimbursementReceivedAt DateTime?

  // ===== Certificate =====

  certificateIssued Boolean @default(false)

  certificateIssuedAt DateTime?

  // timestamps

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Relations

  payments Payment[]

  refunds Refund[]

  attendance Attendance?

  emergencyContact EmergencyContact?

  certificate Certificate?

  // Offline payment support
  offlinePaymentCreated Boolean @default(false)

  offlinePaymentVerified Boolean @default(false)

  paymentMethod String?

  paymentReference String?

  paymentAmount Int?

  paymentRecordedAt DateTime?

  paymentRecordedBy String?

  paymentPortal Boolean @default(false)

  // =========================
  // Booking (Govt Permits)
  // =========================

  bookingAssignedTo String?
}

model Payment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  registrationId String       @db.ObjectId
  registration   Registration @relation(fields: [registrationId], references: [id])

  type PaymentType

  amount Int

  status PaymentStatus @default(LOCKED)

  paymentMethod PaymentMethod?

  razorpayOrderId   String?
  razorpayPaymentId String?

  verifiedBy String?

  paidAt    DateTime?
  reference String?

  notes String?

  // When set, student-facing views show this text instead of "₹{amount}" —
  // e.g. a historical trek paid as part of a combined package on a
  // different trek, so this specific record's amount is 0 but not "unpaid".
  displayOverride String?

  createdAt DateTime @default(now())
}

model Refund {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  registrationId String       @db.ObjectId
  registration   Registration @relation(fields: [registrationId], references: [id])

  amount Int

  status RefundStatus @default(PENDING)

  processedBy String?

  processedAt DateTime?

  createdAt DateTime @default(now())
}

model Expense {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  trekId String @db.ObjectId
  trek   Trek   @relation(fields: [trekId], references: [id])

  title String

  amount Int

  remarks String?

  createdBy String?

  createdAt DateTime @default(now())
}

model Income {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  trekId String @db.ObjectId
  trek   Trek   @relation(fields: [trekId], references: [id])

  title String

  amount Int

  remarks String?

  createdBy String?

  createdAt DateTime @default(now())
}

model Attendance {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  registrationId String       @unique @db.ObjectId
  registration   Registration @relation(fields: [registrationId], references: [id])

  present Boolean @default(false)

  markedBy String?

  markedAt DateTime?
}

model EmergencyContact {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  registrationId String       @unique @db.ObjectId
  registration   Registration @relation(fields: [registrationId], references: [id])

  name String

  relationship String

  phoneNumber String
}

model Gallery {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  trekId String @db.ObjectId
  trek   Trek   @relation(fields: [trekId], references: [id])

  imageUrl String

  uploadedBy String?

  createdAt DateTime @default(now())
}

model Song {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title String

  audioUrl String

  thumbnailUrl String

  order Int @default(0)

  uploadedBy String?

  createdAt DateTime @default(now())
}

model TribeMember {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name String

  role String

  // 1 = Core Leadership (President, Treasurer...), 2 = Department Heads /
  // Team. Roles/titles change every year so this drives the homepage's
  // layout grouping instead of matching on the (unstable) role text.
  tier Int @default(2)

  year String

  course String

  photoUrl String

  bio String

  songTitle String?

  songUrl String?

  order Int @default(0)

  createdAt DateTime @default(now())
}

model InstagramPost {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  postUrl String

  thumbnailUrl String?

  caption String?

  createdAt DateTime @default(now())
}

model Certificate {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  registrationId String       @unique @db.ObjectId
  registration   Registration @relation(fields: [registrationId], references: [id])

  certificateUrl String

  issuedAt DateTime @default(now())
}

model PaymentSettings {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  clubName String

  receiverName String

  upiId String @unique

  supportPhone String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model SocialSettings {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  instagram String?

  linkedin String?

  email String?

  phone String?

  updatedAt DateTime @updatedAt
}

model GoogleEarthSettings {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  earthUrl String

  updatedAt DateTime @updatedAt
}

// The homepage "Things We Do" interactive section — one card per activity,
// admin-editable image + copy instead of the old hardcoded array.
model HomepageActivity {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  icon String

  title String

  description String

  imageUrl String

  highlights String[] @default([])

  difficulty String?

  bestSeason String?

  duration String?

  funFact String?

  buttonText String

  buttonLink String

  order Int @default(0)

  createdAt DateTime @default(now())
}

model TrailStat {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  label String

  value String

  tooltip String?

  order Int @default(0)

  createdAt DateTime @default(now())
}

// The "Adventure Begins By The Numbers" homepage stat cards — admin-editable
// count-up tiles (e.g. "650+ Students").
model HomepageStat {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  value Int

  suffix String?

  label String

  order Int @default(0)

  createdAt DateTime @default(now())
}

model HomepageGalleryPhoto {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  imageUrl String

  caption String?

  category String?

  // Actual upload dimensions, so the /gallery masonry grid can size each
  // next/image at its real aspect ratio instead of forcing a fixed crop.
  // Nullable since photos uploaded before this field existed don't have it.
  width Int?

  height Int?

  order Int @default(0)

  createdAt DateTime @default(now())
}

// Singleton hero banner for the dedicated /gallery page (separate from the
// individual gallery photos above) — admin-editable image/heading/subtitle/
// button, same pattern as GoogleEarthSettings.
model GalleryHeroSettings {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  imageUrl String

  heading String

  subtitle String

  buttonText String?

  buttonLink String?

  updatedAt DateTime @updatedAt
}

model HomepageStory {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  imageUrl String

  title String

  description String

  order Int @default(0)

  published Boolean @default(true)

  createdAt DateTime @default(now())
}

// The animated image+caption carousel in the homepage Stories section
// ("Every Journey Leaves A Mark.") — admin-uploaded photos, shown big with
// the tagline and a description line overlaid on the image itself, one at
// a time with auto-advance.
model HomepageStoryScene {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  imageUrl String

  imageWidth Int

  imageHeight Int

  caption String?

  description String?

  order Int @default(0)

  createdAt DateTime @default(now())
}

model CertificateSettings {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  facultyHeadName String?

  facultyHeadSignatureUrl String?

  presidentName String?

  presidentSignatureUrl String?

  updatedAt DateTime @updatedAt
}

model StudentDashboardSettings {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  bannerImageUrl String?

  updatedAt DateTime @updatedAt
}

model TripAnnouncement {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  trekId String @db.ObjectId

  trek Trek @relation(fields: [trekId], references: [id])

  title String

  message String

  createdBy String?

  createdAt DateTime @default(now())
}

model CoreTeamElection {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  status String @default("DRAFT") // DRAFT | PUBLISHED | CLOSED

  roster String[]

  positions String[]

  createdAt DateTime @default(now())

  publishedAt DateTime?

  closedAt DateTime?

  ballots CoreTeamBallot[]
}

model CoreTeamBallot {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  electionId String           @db.ObjectId
  election   CoreTeamElection @relation(fields: [electionId], references: [id])

  voterId String @db.ObjectId

  voterName String

  selections Json // Record<position, name> — blanks omitted

  submittedAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([electionId, voterId])
}

// A raw single-use token is emailed to the user; only its SHA-256 hash is
// stored here, so a database leak alone can't be used to reset accounts.
model PasswordResetToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId

  tokenHash String @unique

  expiresAt DateTime

  usedAt DateTime?

  createdAt DateTime @default(now())
}

// Tracks who clicked "Notify Me" on a trek whose registration hasn't opened
// yet. Read/written by plain userId/trekId lookups (same shape as
// PasswordResetToken above) rather than Prisma relations, so this doesn't
// require touching the User or Trek models' own field lists.
model TrekNotifyRequest {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  trekId String @db.ObjectId

  userId String @db.ObjectId

  createdAt DateTime @default(now())

  @@unique([trekId, userId])
}